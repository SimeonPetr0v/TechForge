@{
    ViewData["Title"] = "Server Error";
}

<div class="container py-5 text-center tf-error-page">
    <div class="display-1 fw-bold tf-gradient-text">500</div>
    <i class="bi bi-bug tf-error-icon" style="color:var(--tf-danger);"></i>
    <h1 class="h3 mt-3 text-light">Something went wrong</h1>
    <p class="text-muted">An unexpected error occurred on our end. We've logged it and will look into it.</p>
    <a class="btn btn-tf-primary mt-3" asp-controller="Home" asp-action="Index"><i class="bi bi-house me-2"></i>Back to home</a>
</div>
