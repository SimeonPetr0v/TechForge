@{
    ViewData["Title"] = "Page Not Found";
}

<div class="container py-5 text-center tf-error-page">
    <div class="display-1 fw-bold tf-gradient-text">404</div>
    <i class="bi bi-compass tf-error-icon"></i>
    <h1 class="h3 mt-3 text-light">Page not found</h1>
    <p class="text-muted">The page you're looking for doesn't exist or has moved.</p>
    <div class="d-flex justify-content-center gap-2 mt-3">
        <a class="btn btn-tf-primary" asp-controller="Home" asp-action="Index"><i class="bi bi-house me-2"></i>Home</a>
        <a class="btn btn-outline-light" asp-controller="Products" asp-action="Index">Browse catalog</a>
    </div>
</div>
