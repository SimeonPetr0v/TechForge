@{
    ViewData["Title"] = "Forbidden";
}

<div class="container py-5 text-center tf-error-page">
    <div class="display-1 fw-bold tf-gradient-text">403</div>
    <i class="bi bi-shield-lock-fill tf-error-icon" style="color:var(--tf-danger);"></i>
    <h1 class="h3 mt-3 text-light">Access denied</h1>
    <p class="text-muted">You don't have permission to access this resource.</p>
    <a class="btn btn-tf-primary mt-3" asp-controller="Home" asp-action="Index"><i class="bi bi-house me-2"></i>Back to home</a>
</div>
