@{
    ViewData["Title"] = "Unauthorized";
}

<div class="container py-5 text-center tf-error-page">
    <div class="display-1 fw-bold tf-gradient-text">401</div>
    <i class="bi bi-shield-lock tf-error-icon"></i>
    <h1 class="h3 mt-3 text-light">Authentication required</h1>
    <p class="text-muted">You need to sign in to view this page.</p>
    <div class="d-flex justify-content-center gap-2 mt-3">
        <a class="btn btn-tf-primary" asp-controller="Account" asp-action="Login"><i class="bi bi-box-arrow-in-right me-2"></i>Sign in</a>
        <a class="btn btn-outline-light" asp-controller="Home" asp-action="Index">Home</a>
    </div>
</div>
