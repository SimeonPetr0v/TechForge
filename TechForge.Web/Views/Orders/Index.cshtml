@model IReadOnlyList<OrderDto>
@{
    ViewData["Title"] = "My Orders";
}

<div class="container py-4">
    <h1 class="h3 tf-gradient-text mb-4">Order History</h1>

    @if (Model.Count == 0)
    {
        <div class="tf-card p-5 text-center">
            <i class="bi bi-bag" style="font-size:3rem;color:var(--tf-muted);"></i>
            <p class="text-muted mt-3 mb-3">You haven't placed any orders yet.</p>
            <a class="btn btn-tf-primary" asp-controller="Products" asp-action="Index">
                <i class="bi bi-grid-3x3-gap-fill me-2"></i>Start shopping
            </a>
        </div>
    }
    else
    {
        <div class="tf-card p-0">
            <div class="table-responsive">
                <table class="table tf-table mb-0 align-middle">
                    <thead>
                        <tr>
                            <th>Order</th>
                            <th>Date</th>
                            <th>Items</th>
                            <th>Total</th>
                            <th>Status</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var order in Model)
                        {
                            <tr>
                                <td><strong>#@order.Id</strong></td>
                                <td class="text-muted">@order.OrderedOn.ToString("MMM d, yyyy")</td>
                                <td>@order.ItemCount</td>
                                <td class="tf-price">@order.TotalPrice.ToString("C")</td>
                                <td><partial name="_OrderStatusBadge" model="order.Status" /></td>
                                <td class="text-end">
                                    <a class="btn btn-outline-light btn-sm" asp-action="Details" asp-route-id="@order.Id">
                                        View
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>
