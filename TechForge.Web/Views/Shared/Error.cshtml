@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div class="container py-5 text-center">
    <h1 class="display-1 tf-gradient-text">!</h1>
    <h2 class="text-light">Something went wrong.</h2>
    <p class="text-muted">An unexpected error occurred while processing your request.</p>
    @if (Model.ShowRequestId)
    {
        <p class="small text-muted"><strong>Request ID:</strong> <code>@Model.RequestId</code></p>
    }
    <a class="btn btn-tf-primary mt-3" asp-controller="Home" asp-action="Index">Back to home</a>
</div>
