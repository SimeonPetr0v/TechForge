@model IReadOnlyList<OrderDto>
@{
    ViewData["Title"] = "Manage Orders";
    Layout = "_AdminLayout";
}

<h1 class="h3 tf-gradient-text mb-4">Orders</h1>

<div class="tf-card p-0">
    <div class="table-responsive">
        <table class="table tf-table mb-0 align-middle">
            <thead>
                <tr><th>Order</th><th>Date</th><th>Items</th><th>Total</th><th>Status</th><th>Update</th></tr>
            </thead>
            <tbody>
                @if (Model.Count == 0)
                {
                    <tr><td colspan="6" class="text-muted text-center py-4">No orders yet.</td></tr>
                }
                @foreach (var order in Model)
                {
                    <tr>
                        <td><strong>#@order.Id</strong></td>
                        <td class="text-muted">@order.OrderedOn.ToString("MMM d, yyyy")</td>
                        <td>@order.ItemCount</td>
                        <td class="tf-price">@order.TotalPrice.ToString("C")</td>
                        <td><partial name="_OrderStatusBadge" model="order.Status" /></td>
                        <td>
                            <form asp-controller="Admin" asp-action="OrderStatus" method="post" class="d-flex gap-2">
                                <input type="hidden" name="id" value="@order.Id" />
                                <select name="status" class="form-select form-select-sm" style="width:auto;">
                                    @foreach (OrderStatus status in Enum.GetValues(typeof(OrderStatus)))
                                    {
                                        if (order.Status == status.ToString())
                                        {
                                            <option value="@status" selected>@status</option>
                                        }
                                        else
                                        {
                                            <option value="@status">@status</option>
                                        }
                                    }
                                </select>
                                <button type="submit" class="btn btn-outline-light btn-sm">Set</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
