@model CategoryInputDto
@{
    var isEdit = Model.Id != 0;
    ViewData["Title"] = isEdit ? "Edit Category" : "New Category";
    Layout = "_AdminLayout";
}

<h1 class="h3 tf-gradient-text mb-4">@(isEdit ? "Edit category" : "New category")</h1>

<div class="tf-card p-4">
    <form asp-controller="Admin" asp-action="@(isEdit ? "CategoryEdit" : "CategoryCreate")" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
        <input type="hidden" asp-for="Id" />

        <div class="mb-3">
            <label asp-for="Name" class="form-label"></label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger small"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Description" class="form-label"></label>
            <textarea asp-for="Description" class="form-control" rows="2"></textarea>
            <span asp-validation-for="Description" class="text-danger small"></span>
        </div>
        <div class="mb-4">
            <label asp-for="ImageUrl" class="form-label"></label>
            <input asp-for="ImageUrl" class="form-control" placeholder="https://..." />
            <span asp-validation-for="ImageUrl" class="text-danger small"></span>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-tf-primary"><i class="bi bi-save me-2"></i>@(isEdit ? "Save changes" : "Create category")</button>
            <a class="btn btn-outline-light" asp-controller="Admin" asp-action="Categories">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
