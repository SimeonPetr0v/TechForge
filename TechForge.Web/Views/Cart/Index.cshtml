@model CartDto
@{
    ViewData["Title"] = "Shopping Cart";
}

<div class="container py-4">
    <h1 class="h3 tf-gradient-text mb-4">Your Cart</h1>

    @if (Model.IsEmpty)
    {
        <div class="tf-card p-5 text-center">
            <i class="bi bi-cart-x" style="font-size:3rem;color:var(--tf-muted);"></i>
            <p class="text-muted mt-3 mb-3">Your cart is empty.</p>
            <a class="btn btn-tf-primary" asp-controller="Products" asp-action="Index">
                <i class="bi bi-grid-3x3-gap-fill me-2"></i>Browse the catalog
            </a>
        </div>
    }
    else
    {
        <div class="row g-4">
            <div class="col-lg-8">
                <div class="tf-card p-0">
                    @foreach (var item in Model.Items)
                    {
                        <div class="tf-cart-row d-flex align-items-center gap-3 p-3">
                            <a asp-controller="Products" asp-action="Details" asp-route-id="@item.ProductId">
                                @if (!string.IsNullOrEmpty(item.ImageUrl))
                                {
                                    <img src="@item.ImageUrl" alt="@item.ProductName" class="tf-cart-img" />
                                }
                                else
                                {
                                    <div class="tf-cart-img d-flex align-items-center justify-content-center">
                                        <i class="bi bi-cpu text-muted"></i>
                                    </div>
                                }
                            </a>

                            <div class="flex-grow-1">
                                <a class="tf-product-name" asp-controller="Products" asp-action="Details" asp-route-id="@item.ProductId">
                                    @item.ProductName
                                </a>
                                <div class="text-muted small">@item.UnitPrice.ToString("C") each</div>
                            </div>

                            <form asp-controller="Cart" asp-action="UpdateQuantity" method="post" class="d-flex align-items-center gap-2">
                                <input type="hidden" name="productId" value="@item.ProductId" />
                                <input type="number" name="quantity" value="@item.Quantity" min="0" max="@item.StockQuantity"
                                       class="form-control form-control-sm" style="width:72px;" />
                                <button type="submit" class="btn btn-outline-light btn-sm" title="Update">
                                    <i class="bi bi-arrow-repeat"></i>
                                </button>
                            </form>

                            <div class="tf-price text-end" style="min-width:90px;">@item.LineTotal.ToString("C")</div>

                            <form asp-controller="Cart" asp-action="Remove" method="post">
                                <input type="hidden" name="productId" value="@item.ProductId" />
                                <button type="submit" class="btn btn-link text-danger p-0" title="Remove">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </div>
                    }
                </div>

                <form asp-controller="Cart" asp-action="Clear" method="post" class="mt-2 text-end">
                    <button type="submit" class="btn btn-link text-muted btn-sm">Clear cart</button>
                </form>
            </div>

            <div class="col-lg-4">
                <div class="tf-card p-4">
                    <h5 class="mb-3">Summary</h5>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Items</span>
                        <span>@Model.TotalItems</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Subtotal</span>
                        <span class="tf-price">@Model.Subtotal.ToString("C")</span>
                    </div>
                    <div class="d-flex justify-content-between mb-3">
                        <span class="text-muted">Shipping</span>
                        <span class="text-success">Free</span>
                    </div>
                    <hr class="border-secondary" />
                    <div class="d-flex justify-content-between mb-3">
                        <strong>Total</strong>
                        <strong class="tf-price">@Model.Subtotal.ToString("C")</strong>
                    </div>
                    <a class="btn btn-tf-primary w-100" asp-controller="Orders" asp-action="Checkout">
                        <i class="bi bi-bag-check me-2"></i>Proceed to checkout
                    </a>
                </div>
            </div>
        </div>
    }
</div>
