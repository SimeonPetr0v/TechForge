@{
    ViewData["Title"] = "Home";
}

<section class="tf-hero">
    <div class="container py-5 text-center">
        <h1 class="display-3 fw-bold tf-gradient-text mb-3">Forge Your Setup.</h1>
        <p class="lead text-light-emphasis mb-4">
            The dark-mode marketplace for computer parts, peripherals, and the gear that powers your build.
        </p>
        <div class="d-flex justify-content-center gap-2">
            <a class="btn btn-tf-primary btn-lg px-4" asp-controller="Products" asp-action="Index"><i class="bi bi-grid-3x3-gap-fill me-2"></i>Browse Catalog</a>
            <a class="btn btn-outline-light btn-lg px-4" asp-controller="Products" asp-action="Index"><i class="bi bi-cpu me-2"></i>Shop Parts</a>
        </div>
    </div>
</section>

<section class="container py-5">
    <div class="row g-4">
        <div class="col-md-4">
            <div class="tf-card p-4 h-100">
                <i class="bi bi-lightning-charge-fill tf-icon"></i>
                <h4 class="mt-3">Fast Shipping</h4>
                <p class="text-muted small mb-0">Next-day delivery on in-stock items.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="tf-card p-4 h-100">
                <i class="bi bi-shield-check tf-icon"></i>
                <h4 class="mt-3">Verified Parts</h4>
                <p class="text-muted small mb-0">Every product checked against compatibility specs.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="tf-card p-4 h-100">
                <i class="bi bi-graph-up-arrow tf-icon"></i>
                <h4 class="mt-3">Live Pricing</h4>
                <p class="text-muted small mb-0">Real-time deals from trusted vendors.</p>
            </div>
        </div>
    </div>
</section>
