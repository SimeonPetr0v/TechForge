@model HomeViewModel
@{
    ViewData["Title"] = "Home";
}

<section class="tf-hero">
    <div class="container py-5 text-center">
        <h1 class="display-3 fw-bold tf-gradient-text mb-3">Forge Your Setup.</h1>
        <p class="lead text-light-emphasis mb-4">
            The dark-mode marketplace for computer parts, peripherals, and the gear that powers your build.
        </p>
        <div class="d-flex justify-content-center gap-2">
            <a class="btn btn-tf-primary btn-lg px-4" asp-controller="Products" asp-action="Index"><i class="bi bi-grid-3x3-gap-fill me-2"></i>Browse Catalog</a>
            <a class="btn btn-outline-light btn-lg px-4" asp-controller="Products" asp-action="Index"><i class="bi bi-cpu me-2"></i>Shop Parts</a>
        </div>
    </div>
</section>

<!-- Shop by category -->
@if (Model.Categories.Count > 0)
{
    <section class="container py-5">
        <h2 class="h4 mb-4">Shop by category</h2>
        <div class="row row-cols-2 row-cols-md-4 g-3">
            @foreach (var category in Model.Categories)
            {
                <div class="col">
                    <a class="tf-category-tile" asp-controller="Products" asp-action="Index" asp-route-CategoryId="@category.Id">
                        <i class="bi bi-collection"></i>
                        <span class="tf-category-name">@category.Name</span>
                        <span class="tf-category-count">@category.ProductCount item(s)</span>
                    </a>
                </div>
            }
        </div>
    </section>
}

<!-- Featured products -->
@if (Model.Featured.Count > 0)
{
    <section class="container py-4">
        <div class="d-flex align-items-center justify-content-between mb-4">
            <h2 class="h4 mb-0"><i class="bi bi-star-fill text-warning me-2"></i>Featured deals</h2>
            <a asp-controller="Products" asp-action="Index" class="small">View all</a>
        </div>
        <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-4 g-4">
            @foreach (var product in Model.Featured)
            {
                <div class="col"><partial name="_ProductCard" model="product" /></div>
            }
        </div>
    </section>
}

<!-- New arrivals -->
@if (Model.Newest.Count > 0)
{
    <section class="container py-4">
        <div class="d-flex align-items-center justify-content-between mb-4">
            <h2 class="h4 mb-0"><i class="bi bi-lightning-charge-fill text-info me-2"></i>New arrivals</h2>
            <a asp-controller="Products" asp-action="Index" asp-route-Sort="Newest" class="small">View all</a>
        </div>
        <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-4 g-4">
            @foreach (var product in Model.Newest)
            {
                <div class="col"><partial name="_ProductCard" model="product" /></div>
            }
        </div>
    </section>
}

<!-- Trust badges -->
<section class="container py-5">
    <div class="row g-4">
        <div class="col-md-4">
            <div class="tf-card p-4 h-100">
                <i class="bi bi-lightning-charge-fill tf-icon"></i>
                <h4 class="mt-3">Fast Shipping</h4>
                <p class="text-muted small mb-0">Next-day delivery on in-stock items.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="tf-card p-4 h-100">
                <i class="bi bi-shield-check tf-icon"></i>
                <h4 class="mt-3">Verified Parts</h4>
                <p class="text-muted small mb-0">Every product checked against compatibility specs.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="tf-card p-4 h-100">
                <i class="bi bi-graph-up-arrow tf-icon"></i>
                <h4 class="mt-3">Live Pricing</h4>
                <p class="text-muted small mb-0">Real-time deals from trusted vendors.</p>
            </div>
        </div>
    </div>
</section>
